# === REQUIRED (server refuses to start in production without these) ===

# Telegram bot token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to access the terminal
ALLOWED_USER_IDS=123456789

# Random string for JWT session signing (generate: openssl rand -hex 32)
SESSION_SECRET=your_random_32_char_string_here

# Production = fail-fast on missing required env, plus stricter logging
NODE_ENV=production

# === OPTIONAL ===

# Server port (default: 7681)
PORT=7681

# Path to RS256 public key for /terminal bot command JWT verification
# Only needed if you use a bot command to generate access tokens
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Management API token — allows remote command execution via POST /api/exec
# Leave empty to disable the management API entirely.
MGMT_TOKEN=

# Optional path for /api/exec audit log (append-only). Leave empty to skip.
MGMT_AUDIT_LOG=

# Allowed HTTPS origins for WebSocket connections (comma-separated)
# Set to your actual domain. Empty = accept any origin (dev only).
ALLOWED_ORIGINS=https://terminal.yourdomain.com

# Shell command to spawn (default: tmux with new-session)
SHELL_COMMAND=tmux
SHELL_ARGS=new-session,-A,-s

# Working directory for terminal sessions (default: $HOME)
SHELL_CWD=

# Max concurrent terminal tabs per user (default: 4)
MAX_SESSIONS=4

# Idle timeout in minutes before session is killed (default: 30)
IDLE_TIMEOUT_MINUTES=30

# Opt-in audit logging via tmux pipe-pane.
# Captures FULL terminal output (including AI agent prompts and replies).
# Treat the directory as sensitive. Leave empty to disable.
AUDIT_LOG_DIR=

# === VOICE INPUT (optional) ===
# Azure OpenAI Whisper endpoint for server-side voice transcription.
# Leave empty to use browser-only Web Speech API (no server call).
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=your_azure_api_key_here

# Whisper deployment name (default: whisper)
WHISPER_DEPLOYMENT=whisper

# Default voice language (default: en)
VOICE_LANGUAGE=en

# === TELEGRAM LOGIN WIDGET (optional) ===
# Lets you sign in with Telegram from a desktop browser, not just inside the
# Telegram Mini App. The bot's @username (without the @) goes here. You also
# have to whitelist this server's domain via @BotFather: /setdomain.
# Leave empty to disable — the page will show the "open in Telegram" fallback.
LOGIN_WIDGET_BOT=
